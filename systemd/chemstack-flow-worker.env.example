# ChemStack flow worker environment
#
# Copy this file to a host-local path such as:
#   /etc/chemstack/flow-worker.env
# Then edit the values for your machine.

# Optional: repo root and Python interpreter used by the workflow worker service.
CHEM_FLOW_CHEMSTACK_REPO_ROOT=/home/daehyupsohn/chemstack
CHEM_FLOW_PYTHON=/home/daehyupsohn/chemstack/.venv/bin/python

# Required in chemstack.yaml: set workflow.root to the materialized workflow tree.
# Optional: point the worker service at the shared chemstack.yaml, or override
# workflow.root directly with CHEM_FLOW_WORKFLOW_ROOT.
CHEM_FLOW_CONFIG=/home/daehyupsohn/chemstack/config/chemstack.yaml
CHEM_FLOW_WORKFLOW_ROOT=

# Optional worker tuning.
CHEM_FLOW_INTERVAL_SECONDS=30
CHEM_FLOW_LOCK_TIMEOUT_SECONDS=5
CHEM_FLOW_REFRESH_REGISTRY=1
CHEM_FLOW_REFRESH_EACH_CYCLE=0
CHEM_FLOW_NO_SUBMIT=0
CHEM_FLOW_MAX_CYCLES=0

# Optional workflow-level Telegram notifications driven by journal events.
# By default, if bot/chat are set, these event types are notified:
#   workflow_status_changed, workflow_advance_failed,
#   worker_started, worker_stopped, worker_interrupted, worker_lock_error
CHEM_FLOW_TELEGRAM_BOT_TOKEN=
CHEM_FLOW_TELEGRAM_CHAT_ID=
CHEM_FLOW_NOTIFY_EVENT_TYPES=
CHEM_FLOW_NOTIFY_DISABLED=0
