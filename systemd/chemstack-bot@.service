[Unit]
Description=ChemStack unified Telegram bot for %i
After=network-online.target
Wants=network-online.target
PartOf=chemstack-runtime@%i.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/chemstack
Environment=PYTHONUNBUFFERED=1
Environment=CHEMSTACK_CONFIG=/home/%i/chemstack/config/chemstack.yaml
ExecStart=/home/%i/chemstack/.venv/bin/python -m chemstack.cli bot
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
