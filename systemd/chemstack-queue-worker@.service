[Unit]
Description=ChemStack unified queue workers for %i
After=local-fs.target
PartOf=chemstack-runtime@%i.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/chemstack
Environment=PYTHONUNBUFFERED=1
Environment=CHEMSTACK_CONFIG=/home/%i/chemstack/config/chemstack.yaml
ExecStart=/home/%i/chemstack/.venv/bin/python -m chemstack.services.queue_worker
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
