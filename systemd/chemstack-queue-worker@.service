[Unit]
Description=ChemStack unified engine queue workers for %i
After=local-fs.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/chemstack
Environment=PYTHONUNBUFFERED=1
Environment=CHEMSTACK_CONFIG=/home/%i/chemstack/config/chemstack.yaml
ExecStart=/home/%i/chemstack/.venv/bin/python -m chemstack.cli queue worker --app orca --app xtb --app crest
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
