runtime:
  # Required: absolute Linux path to the directory tree that contains reaction runs.
  allowed_root: "/path/to/orca_runs"
  # Optional: if omitted, defaults to a sibling "orca_outputs" directory next to allowed_root.
  organized_root: "/path/to/orca_outputs"
  default_max_retries: 2

paths:
  # Required: absolute Linux path to the ORCA executable.
  orca_executable: "/path/to/orca/orca"

# Telegram notification settings (both bot_token and chat_id are required to enable)
telegram:
  bot_token: ""
  chat_id: ""
