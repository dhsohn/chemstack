#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="$ROOT/.venv/bin/python3"
if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="$(command -v python3)"
fi

args=("$@")

detect_command() {
  local i=0
  while (( i < ${#args[@]} )); do
    local token="${args[i]}"
    case "$token" in
      --config)
        ((i += 2))
        continue
        ;;
      --verbose|-v)
        ((i += 1))
        continue
        ;;
      --)
        if (( i + 1 < ${#args[@]} )); then
          printf '%s' "${args[i + 1]}"
        fi
        return 0
        ;;
      -*)
        ((i += 1))
        continue
        ;;
      *)
        printf '%s' "$token"
        return 0
        ;;
    esac
  done
  return 0
}

cmd="$(detect_command)"

if [[ "$cmd" == "run-inp" ]]; then
  want_background=1
  case "${ORCA_AUTO_RUN_INP_BACKGROUND:-1}" in
    0|false|FALSE|False|no|NO|No|off|OFF|Off)
      want_background=0
      ;;
  esac

  filtered=()
  for arg in "${args[@]}"; do
    case "$arg" in
      -h|--help)
        want_background=0
        filtered+=("$arg")
        ;;
      --foreground)
        want_background=0
        ;;
      --background)
        want_background=1
        ;;
      *)
        filtered+=("$arg")
        ;;
    esac
  done
  args=("${filtered[@]}")

  if (( want_background == 1 )); then
    reaction_dir=""
    for ((i = 0; i < ${#args[@]}; i++)); do
      token="${args[i]}"
      case "$token" in
        --reaction-dir)
          if (( i + 1 < ${#args[@]} )); then
            reaction_dir="${args[i + 1]}"
          fi
          ;;
        --reaction-dir=*)
          reaction_dir="${token#--reaction-dir=}"
          ;;
      esac
    done

    mkdir -p "$ROOT/logs"
    timestamp="$(date +'%Y%m%d_%H%M%S')"
    label="runinp"
    if [[ -n "$reaction_dir" ]]; then
      label="$(basename "$reaction_dir")"
      label="$(printf '%s' "$label" | tr -cd 'A-Za-z0-9._-')"
      if [[ -z "$label" ]]; then
        label="runinp"
      fi
    fi
    log_file="$ROOT/logs/run_inp_${timestamp}_${label}.log"

    PYTHONPATH="$ROOT:${PYTHONPATH:-}" nohup "$PYTHON_BIN" -m core.cli "${args[@]}" >"$log_file" 2>&1 < /dev/null &
    bg_pid="$!"

    sleep 0.2
    if kill -0 "$bg_pid" 2>/dev/null; then
      printf 'status: started\n'
      printf 'pid: %s\n' "$bg_pid"
      printf 'log: %s\n' "$log_file"
      exit 0
    fi

    if wait "$bg_pid"; then
      printf 'status: finished\n'
      printf 'pid: %s\n' "$bg_pid"
      printf 'log: %s\n' "$log_file"
      exit 0
    fi

    printf 'status: failed_early\n'
    printf 'pid: %s\n' "$bg_pid"
    printf 'log: %s\n' "$log_file"
    if [[ -s "$log_file" ]]; then
      printf 'last_log_lines:\n'
      tail -n 20 "$log_file"
    fi
    exit 1
  fi
fi

PYTHONPATH="$ROOT:${PYTHONPATH:-}" exec "$PYTHON_BIN" -m core.cli "${args[@]}"
