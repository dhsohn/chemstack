#!/usr/bin/env bash
set -euo pipefail
SELF="${BASH_SOURCE[0]}"
[[ -L "$SELF" ]] && SELF="$(readlink -f "$SELF")"
ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"
PYTHON_BIN="$ROOT/.venv/bin/python3"
if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="$(command -v python3)"
fi

PYTHONPATH="$ROOT:${PYTHONPATH:-}" exec "$PYTHON_BIN" -m core.launcher "$@"
